generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  lang      String   @default("sl")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  lang      String   @default("sl")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HoneyOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  name          String
  email         String
  phone         String
  street        String
  city          String
  postalCode    String
  notes         String   @default("")
  paymentMethod String
  items         String
  subtotal      Float
  shippingCost  Float
  total         Float
  status        String   @default("new")
  lang          String   @default("sl")
  createdAt     DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  content   String
  image     String   @default("/images/hero.jpg")
  author    String   @default("Jožef Veselič")
  category  String
  published Boolean  @default(true)
  lang      String   @default("sl")
  createdAt DateTime @default(now())
}
